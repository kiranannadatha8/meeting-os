# ============================================================
# MeetingOS — environment variables
# Copy to .env.local and fill in the values you need.
# W1 Foundation runs without any external API keys.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://meetingos:meetingos@localhost:5432/meetingos
REDIS_URL=redis://localhost:6379/0

# --- NextAuth (Google OAuth) — required from T04 ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-run-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI providers — required from T07 (OpenAI) and T11 (Anthropic) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- LangSmith tracing (optional in dev) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=meeting-os-dev
LANGCHAIN_API_KEY=

# --- MCP integrations — required from T17 ---
# 32-byte AES-256-GCM key for encrypting integration credentials at rest.
# Generate: python -c "from app.mcp.crypto import generate_key; print(generate_key())"
MEETING_OS_ENCRYPTION_KEY=

# Optional test credentials for Linear + Gmail integration tests (T18, T19).
LINEAR_API_KEY=
GMAIL_REFRESH_TOKEN=

# --- App config ---
APP_ENV=development
LOG_LEVEL=info
