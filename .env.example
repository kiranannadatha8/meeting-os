# ============================================================
# MeetingOS — environment variables
# Copy to .env (for docker compose) or .env.local (for local dev).
# Docker boots without any external API keys; features light up
# as you fill in the corresponding sections below.
# ============================================================

# --- Database + queue ---
DATABASE_URL=postgresql+psycopg://meetingos:meetingos@localhost:5432/meetingos
REDIS_URL=redis://localhost:6379/0

# --- Web → API base URL ---
# Local dev (pnpm dev:web):     http://localhost:8000
# Docker Compose (web service): http://api:8000   (overridden in docker-compose.yml)
API_BASE_URL=http://localhost:8000

# --- NextAuth (Google OAuth) — required from T04 ---
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-run-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI providers — required from T07 (OpenAI) and T11 (Anthropic) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- LangSmith tracing (optional in dev) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=meeting-os-dev
LANGCHAIN_API_KEY=

# --- MCP integrations — required from T17 ---
# 32-byte Fernet key for encrypting integration credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEETING_OS_ENCRYPTION_KEY=

# Optional test credentials for Linear + Gmail integration tests (T18, T19).
LINEAR_API_KEY=
GMAIL_REFRESH_TOKEN=

# --- App config ---
APP_ENV=development
LOG_LEVEL=info
